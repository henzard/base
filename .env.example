# Environment variables template.
# Copy to .env and fill with real values. NEVER commit .env.
# Ref: powerhouse.mdc security, .gitignore, .cursorignore.

# App
# NODE_ENV=development
# PORT=3000

# Database
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Auth
# JWT_SECRET=change-me-to-a-real-secret
# AUTH_PROVIDER_CLIENT_ID=
# AUTH_PROVIDER_CLIENT_SECRET=

# Third-party services
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Cloud / infra
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
